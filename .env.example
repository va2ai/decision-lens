# Provider — LiteLLM speaks all of these. Pick one.
# OpenAI
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Anthropic (alternate)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5

# Vertex AI / Gemini (alternate — no code change required)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# VERTEXAI_PROJECT=your-gcp-project
# VERTEXAI_LOCATION=us-central1
# LLM_MODEL=vertex_ai/gemini-2.5-pro

# Embeddings (used by the retrieval agent)
EMBEDDING_MODEL=text-embedding-3-small

# Observability — optional. Falls back to local JSONL traces if unset.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Runtime
LOG_LEVEL=INFO
TRACE_DIR=./traces
CHROMA_DIR=./.chroma
